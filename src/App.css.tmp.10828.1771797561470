/* ── Base layout ───────────────────────────────────────── */
.app {
  min-height: 100vh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 2rem 1rem 4rem;
  background: linear-gradient(160deg, #43cea2 0%, #185a9d 100%);
}

.card {
  background: #fff;
  border-radius: 20px;
  box-shadow: 0 24px 64px rgba(0, 0, 0, 0.18);
  padding: 1.75rem 1.75rem 1.25rem;
  width: 100%;
  max-width: 520px;
  color: #333;
}

/* ── Header ────────────────────────────────────────────── */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1.25rem;
  gap: 0.75rem;
}

.header h1 {
  margin: 0;
  font-size: 1.65rem;
  color: #1a1a2e;
}

.mode-btn {
  flex-shrink: 0;
  padding: 0.5rem 1.1rem;
  border: none;
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 700;
  cursor: pointer;
  letter-spacing: 0.02em;
  transition: opacity 0.2s, transform 0.1s;
}
.mode-btn:active { transform: scale(0.96); }
.mode-btn:disabled { opacity: 0.4; cursor: not-allowed; }

.mode-btn.shop {
  background: #22c55e;
  color: #fff;
}
.mode-btn.shop:not(:disabled):hover { opacity: 0.85; }

.mode-btn.edit {
  background: #f59e0b;
  color: #fff;
}
.mode-btn.edit:hover { opacity: 0.85; }

/* ── Add section (toggle + forms) ──────────────────────── */
.add-section {
  margin-bottom: 1.25rem;
}

.add-toggle {
  display: flex;
  gap: 0.4rem;
  margin-bottom: 0.6rem;
}

.toggle-btn {
  padding: 0.35rem 0.9rem;
  border: 2px solid #e2e8f0;
  border-radius: 999px;
  background: #fff;
  color: #94a3b8;
  font-size: 0.82rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}
.toggle-btn.active {
  border-color: #43cea2;
  color: #43cea2;
  background: #f0fefb;
}

.bulk-form {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.bulk-form textarea {
  width: 100%;
  padding: 0.7rem 0.9rem;
  border: 2px solid #e2e8f0;
  border-radius: 10px;
  font-size: 0.95rem;
  font-family: inherit;
  color: #333;
  resize: vertical;
  outline: none;
  box-sizing: border-box;
  transition: border-color 0.2s;
  line-height: 1.6;
}
.bulk-form textarea:focus { border-color: #43cea2; }

.bulk-add-btn {
  align-self: flex-end;
  padding: 0.6rem 1.4rem;
}

/* ── Add form ───────────────────────────────────────────── */
.add-form {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
  flex-wrap: wrap;
}

.add-form input {
  flex: 1 1 140px;
  padding: 0.6rem 0.9rem;
  border: 2px solid #e2e8f0;
  border-radius: 10px;
  font-size: 0.95rem;
  outline: none;
  color: #333;
  transition: border-color 0.2s;
}
.add-form input:focus { border-color: #43cea2; }

.add-form select {
  flex: 0 1 auto;
  padding: 0.6rem 0.7rem;
  border: 2px solid #e2e8f0;
  border-radius: 10px;
  font-size: 0.9rem;
  background: #fff;
  color: #333;
  cursor: pointer;
  outline: none;
  transition: border-color 0.2s;
}
.add-form select:focus { border-color: #43cea2; }

.add-btn {
  padding: 0.6rem 1.1rem;
  background: #43cea2;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 0.95rem;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.2s;
}
.add-btn:hover { background: #36b08b; }

/* ── Progress bar ───────────────────────────────────────── */
.progress-wrap {
  margin-bottom: 1.25rem;
}

.progress-bar {
  height: 10px;
  background: #e2e8f0;
  border-radius: 999px;
  overflow: hidden;
  display: flex;
  margin-bottom: 0.4rem;
}

.bar-bag {
  background: #22c55e;
  transition: width 0.4s ease;
}
.bar-miss {
  background: #f87171;
  transition: width 0.4s ease;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.8rem;
}
.lbl-bag  { color: #22c55e; font-weight: 600; }
.lbl-pend { color: #94a3b8; }
.lbl-miss { color: #f87171; font-weight: 600; }

/* ── Category group ─────────────────────────────────────── */
.category-group {
  margin-bottom: 0.75rem;
}

.category-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.35rem 0.5rem;
  background: #f1f5f9;
  border-radius: 8px;
  margin-bottom: 0.25rem;
}

.cat-emoji { font-size: 1.1rem; line-height: 1; }
.cat-label { font-weight: 700; font-size: 0.9rem; color: #374151; flex: 1; }
.cat-count {
  font-size: 0.78rem;
  background: #cbd5e1;
  color: #475569;
  border-radius: 999px;
  padding: 0.1rem 0.55rem;
  font-weight: 600;
}

/* ── Product list ───────────────────────────────────────── */
.product-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.product-item {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.6rem 0.5rem 0.6rem 1.5rem;
  border-bottom: 1px solid #f1f5f9;
  transition: background 0.15s, opacity 0.2s;
}
.product-item:last-child { border-bottom: none; }

/* Status tints */
.status-in_bag {
  background: #f0fdf4;
  opacity: 0.7;
}
.status-not_found {
  background: #fff5f5;
  opacity: 0.6;
}

.product-name {
  flex: 1;
  font-size: 0.95rem;
  color: #1e293b;
}

.status-in_bag  .product-name { text-decoration: line-through; color: #86efac; }
.status-not_found .product-name { text-decoration: line-through; color: #fca5a5; }

/* ── Price tags ─────────────────────────────────────────── */
.price-tag {
  font-size: 0.75rem;
  font-weight: 700;
  border-radius: 6px;
  padding: 0.1rem 0.4rem;
  white-space: nowrap;
  flex-shrink: 0;
  border: 1px solid transparent;
  transition: transform 0.1s;
}
.price-tag.shufersal {
  color: #16a34a;
  background: #f0fdf4;
  border-color: #bbf7d0;
}
.price-tag.rami-levi {
  color: #b91c1c;
  background: #fff5f5;
  border-color: #fecaca;
}
.price-tag.hetzi-hinam {
  color: #92400e;
  background: #fffbeb;
  border-color: #fde68a;
}
.price-tag.cheaper {
  outline: 2px solid #facc15;
  font-size: 0.8rem;
}
.price-unit {
  font-weight: 400;
  opacity: 0.7;
}

/* ── Edit: delete button ────────────────────────────────── */
.delete-btn {
  background: transparent;
  border: none;
  color: #cbd5e1;
  font-size: 0.9rem;
  cursor: pointer;
  padding: 0.25rem 0.45rem;
  border-radius: 6px;
  transition: color 0.2s, background 0.2s;
  line-height: 1;
}
.delete-btn:hover {
  color: #ef4444;
  background: #fee2e2;
}

/* ── Shopping: action buttons ───────────────────────────── */
.action-btns {
  display: flex;
  gap: 0.35rem;
}

.bag-btn, .miss-btn {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  border: 2px solid transparent;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
  line-height: 1;
}

.bag-btn {
  background: #f0fdf4;
  border-color: #bbf7d0;
  color: #16a34a;
}
.bag-btn:hover, .bag-btn.active {
  background: #22c55e;
  border-color: #22c55e;
  color: #fff;
}

.miss-btn {
  background: #fff5f5;
  border-color: #fecaca;
  color: #dc2626;
}
.miss-btn:hover, .miss-btn.active {
  background: #ef4444;
  border-color: #ef4444;
  color: #fff;
}

/* ── Cost comparison panel ──────────────────────────────── */
.cost-panel {
  background: #f8fafc;
  border: 1.5px solid #e2e8f0;
  border-radius: 14px;
  padding: 1rem 1.1rem;
  margin-bottom: 1.25rem;
}
.cost-title {
  margin: 0 0 0.75rem;
  font-size: 0.95rem;
  color: #1e293b;
  font-weight: 700;
}
.cost-rows {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.cost-row {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.55rem 0.8rem;
  border-radius: 10px;
  border: 2px solid transparent;
  background: #fff;
}
.cost-row.shufersal   { border-color: #bbf7d0; }
.cost-row.rami-levi   { border-color: #fecaca; }
.cost-row.hetzi-hinam { border-color: #fde68a; }
.cost-row.cheapest    { border-width: 2.5px; box-shadow: 0 0 0 3px #fef08a; }
.cost-store { font-weight: 700; font-size: 0.9rem; flex: 1; color: #374151; }
.cost-items { font-size: 0.78rem; color: #94a3b8; }
.cost-total { font-size: 1.1rem; font-weight: 800; color: #1e293b; }
.cost-verdict {
  margin-top: 0.75rem;
  text-align: center;
  font-size: 0.88rem;
  font-weight: 700;
  color: #16a34a;
  background: #f0fdf4;
  border-radius: 8px;
  padding: 0.4rem;
}

/* ── Empty state ────────────────────────────────────────── */
.empty {
  text-align: center;
  color: #94a3b8;
  padding: 2rem 0 1rem;
  font-size: 0.95rem;
  font-style: italic;
}

/* ── Footer ─────────────────────────────────────────────── */
.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.82rem;
  color: #94a3b8;
  padding-top: 0.75rem;
  margin-top: 0.5rem;
  border-top: 1px solid #f1f5f9;
}

.clear-btn {
  background: transparent;
  border: none;
  color: #94a3b8;
  font-size: 0.82rem;
  cursor: pointer;
  padding: 0;
  text-decoration: underline;
}
.clear-btn:hover { color: #ef4444; }

/* ── Email report section ── */
.email-section {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
  padding: 0.75rem 1rem;
  background: #f8fafc;
  border-radius: 10px;
  margin-bottom: 1rem;
}
.email-input {
  flex: 1;
  min-width: 180px;
  padding: 0.45rem 0.75rem;
  border: 1.5px solid #cbd5e1;
  border-radius: 8px;
  font-size: 0.9rem;
  outline: none;
}
.email-input:focus { border-color: #6366f1; }
.send-btn {
  padding: 0.45rem 1rem;
  background: #6366f1;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 0.9rem;
  cursor: pointer;
  white-space: nowrap;
}
.send-btn:hover:not(:disabled) { background: #4f46e5; }
.send-btn:disabled { opacity: 0.6; cursor: default; }
.email-ok  { color: #16a34a; font-size: 0.85rem; font-weight: 600; }
.email-err { color: #dc2626; font-size: 0.85rem; }
